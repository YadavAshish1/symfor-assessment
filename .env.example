# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:npg_cFvn1XpTPrO3@ep-quiet-king-adqp2w8r-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT
JWT_SECRET=change_this_to_something_long_and_random
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another_long_random_secret
