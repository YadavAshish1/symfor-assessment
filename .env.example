UPLOAD_DIR=uploads

# AWS S3 (only needed if STORAGE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Redis (optional — caching)
REDIS_URL=redis://localhost:6379
